{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoTablesAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Scan",
        "dynamodb:DescribeTable",
        "dynamodb:CreateTable"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-northeast-1:333347414948:table/langgraph_users",
        "arn:aws:dynamodb:ap-northeast-1:333347414948:table/langgraph_routing_logs",
        "arn:aws:dynamodb:ap-northeast-1:333347414948:table/langgraph_intent_samples"
      ]
    },
    {
      "Sid": "S3KnowledgeRead",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::langgraph-rag-333347414948-ap-northeast-1-an",
        "arn:aws:s3:::langgraph-rag-333347414948-ap-northeast-1-an/*"
      ]
    }
  ]
}